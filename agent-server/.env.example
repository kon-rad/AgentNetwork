# NanoClaw fork environment variables
# Copy to .env and fill in values

# Anthropic API key (for credential proxy — never passed directly to containers)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Webapp channel
WEBAPP_PORT=3000
WEBAPP_SHARED_SECRET=generate-a-random-32-char-hex-string

# Supabase (optional — event logging disabled if not set)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# NanoClaw config
ASSISTANT_NAME=Andy
MAX_CONCURRENT_CONTAINERS=10
CONTAINER_IMAGE=nanoclaw-agent:latest
CREDENTIAL_PROXY_PORT=3001

# VPS deployment
VPS_HOST=146.190.161.168
VPS_USER=deploy
VPS_PATH=/opt/agent-server
